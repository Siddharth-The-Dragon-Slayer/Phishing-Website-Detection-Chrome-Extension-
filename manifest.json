{
  "manifest_version": 3,
  "name": "DMBI Phishing Detection Assistant",
  "version": "1.0",
  "description": "Real-time phishing detection using machine learning",
  
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  
  "background": {
    "service_worker": "background_simple.js"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["simple_detector.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "🛡️ Phishing Detector"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["models/*"],
      "matches": ["<all_urls>"]
    }
  ]
}